<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="container app-shell">
      <header class="page-header">
        <p class="eyebrow">Sesion de evaluacion</p>
        <h1>Examen en linea</h1>
        <p class="lead">
          Responde todas las preguntas. Puedes usar teclado, mouse o comandos por voz.
        </p>
      </header>

      <section class="panel progress-panel" aria-labelledby="progreso-titulo">
        <h2 id="progreso-titulo">Progreso de respuestas</h2>
        <p class="progress-copy">
          Completadas: <strong><span id="answeredCount">0</span> de <%= questions.length %></strong>
        </p>
        <div class="progress-track" aria-hidden="true">
          <div class="progress-fill" id="progressFill"></div>
        </div>
      </section>

      <section class="panel command-panel" aria-labelledby="comandos-titulo">
        <h2 id="comandos-titulo">Asistencia por voz</h2>
        <p>
          Comandos de voz disponibles: <code>enviar</code>, <code>inicio</code>, <code>limpiar</code>.
          La lectura automatica se activa al moverte por preguntas y opciones.
        </p>
        <div class="command-row">
          <div class="command-actions">
            <button class="btn btn-secondary" type="button" id="readPageBtn" aria-label="Escuchar lectura de la pantalla actual">
              Leer pantalla
            </button>
            <button class="btn btn-secondary" type="button" id="voiceCommandBtn" aria-label="Iniciar reconocimiento de voz para comandos">
              Comando por voz
            </button>
            <button class="btn btn-secondary" type="button" id="micTestBtn" aria-label="Probar si el microfono detecta audio">
              Probar microfono
            </button>
            <button class="btn btn-secondary" type="button" id="toggleAutoReadBtn" aria-label="Activar o desactivar lectura automatica al navegar por preguntas y opciones">
              Lectura auto: ON
            </button>
          </div>
        </div>
        <p id="commandStatus" class="assistive-status" role="status" aria-live="polite"></p>
        <details class="voice-debug" id="voiceDebugPanel">
          <summary>Diagnostico de voz</summary>
          <ul>
            <li>Contexto seguro: <strong id="diagSecureContext">-</strong></li>
            <li>SpeechRecognition disponible: <strong id="diagRecognition">-</strong></li>
            <li>SpeechSynthesis disponible: <strong id="diagSynthesis">-</strong></li>
            <li>Microfono (permiso): <strong id="diagMicPermission">-</strong></li>
            <li>Estado de escucha: <strong id="diagListeningState">-</strong></li>
            <li>Nivel de microfono: <strong id="diagMicLevel">-</strong></li>
            <li>Ultimo error tecnico: <strong id="diagLastError">ninguno</strong></li>
            <li>Ultimo texto reconocido: <strong id="diagLastTranscript">-</strong></li>
          </ul>
        </details>
      </section>

      <% if (errors.length > 0) { %>
      <div class="alert alert-error" role="alert" aria-live="assertive">
        <p><strong>⚠ Revisa tu envio:</strong></p>
        <ul>
          <% errors.forEach((error) => { %>
          <li><%= error.msg %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form action="/exam/take" method="POST" id="examForm">
        <% questions.forEach((question, index) => { %>
        <fieldset class="question question-card" data-question-card>
          <legend>
            <span class="question-badge">Pregunta <%= index + 1 %></span>
            <span class="question-text"><%= question.prompt %></span>
          </legend>

          <label>
            <input
              type="radio"
              name="question_<%= question.id %>"
              value="A"
              <%= oldAnswers[`question_${question.id}`] === "A" ? "checked" : "" %>
            />
            <span class="option-tag" aria-hidden="true">A</span> <%= question.optionA %>
          </label>

          <label>
            <input
              type="radio"
              name="question_<%= question.id %>"
              value="B"
              <%= oldAnswers[`question_${question.id}`] === "B" ? "checked" : "" %>
            />
            <span class="option-tag" aria-hidden="true">B</span> <%= question.optionB %>
          </label>

          <label>
            <input
              type="radio"
              name="question_<%= question.id %>"
              value="C"
              <%= oldAnswers[`question_${question.id}`] === "C" ? "checked" : "" %>
            />
            <span class="option-tag" aria-hidden="true">C</span> <%= question.optionC %>
          </label>
        </fieldset>
        <% }) %>

        <button class="btn btn-primary" type="submit" aria-label="Enviar respuestas del examen">
          <span aria-hidden="true">✅</span> Enviar respuestas
        </button>
      </form>
    </main>
    <script src="/js/accessibility.js"></script>
  </body>
</html>
