<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="container app-shell" data-page-read="Has iniciado el examen. Usa tabulacion para recorrer preguntas y espacio para seleccionar opciones.">
      <header class="page-header">
        <p class="eyebrow">Sesion de evaluacion</p>
        <h1>Examen en linea</h1>
        <p class="lead">
          Responde todas las preguntas. Puedes usar teclado o mouse con soporte para lector de pantalla.
        </p>
      </header>

      <section class="panel progress-panel" aria-labelledby="progreso-titulo">
        <h2 id="progreso-titulo">Progreso de respuestas</h2>
        <p class="progress-copy">
          Completadas: <strong><span id="answeredCount">0</span> de <%= questions.length %></strong>
        </p>
        <div class="progress-track" aria-hidden="true">
          <div class="progress-fill" id="progressFill"></div>
        </div>
      </section>

      <section class="panel command-panel" aria-labelledby="comandos-titulo">
        <h2 id="comandos-titulo">Controles y accesibilidad</h2>
        <p>
          Puedes operar el examen con mouse o teclado. Atajos: <code>Alt+L</code> limpiar,
          <code>Alt+I</code> inicio, <code>Ctrl+Enter</code> enviar. Activa lectura guiada para escuchar preguntas y opciones.
        </p>
        <div class="command-row">
          <div class="command-actions">
            <button class="btn btn-secondary" type="button" id="toggleReadBtn" aria-label="Activar o desactivar lectura guiada en espanol" data-speak="Activar o desactivar lectura guiada.">
              Lectura guiada: ON
            </button>
            <button class="btn btn-secondary" type="button" id="clearAnswersBtn" aria-label="Limpiar respuestas seleccionadas del examen" data-speak="Limpiar respuestas seleccionadas.">
              Limpiar respuestas
            </button>
            <button class="btn btn-secondary" type="button" id="goHomeBtn" aria-label="Volver al inicio del examen" data-speak="Volver al inicio del examen.">
              Ir al inicio
            </button>
          </div>
        </div>
        <p id="commandStatus" class="assistive-status" role="status" aria-live="polite"></p>
      </section>

      <% if (errors.length > 0) { %>
      <div class="alert alert-error" role="alert" aria-live="assertive">
        <p><strong>⚠ Revisa tu envio:</strong></p>
        <ul>
          <% errors.forEach((error) => { %>
          <li><%= error.msg %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <form action="/exam/take" method="POST" id="examForm">
        <% questions.forEach((question, index) => { %>
        <fieldset class="question question-card" data-question-card>
          <legend>
            <span class="question-badge">Pregunta <%= index + 1 %></span>
            <span class="question-text"><%= question.prompt %></span>
          </legend>

          <label>
            <input
              type="radio"
              name="question_<%= question.id %>"
              value="A"
              aria-label="Pregunta <%= index + 1 %> opcion A <%= question.optionA %>"
              <%= oldAnswers[`question_${question.id}`] === "A" ? "checked" : "" %>
            />
            <span class="option-tag" aria-hidden="true">A</span> <%= question.optionA %>
          </label>

          <label>
            <input
              type="radio"
              name="question_<%= question.id %>"
              value="B"
              aria-label="Pregunta <%= index + 1 %> opcion B <%= question.optionB %>"
              <%= oldAnswers[`question_${question.id}`] === "B" ? "checked" : "" %>
            />
            <span class="option-tag" aria-hidden="true">B</span> <%= question.optionB %>
          </label>

          <label>
            <input
              type="radio"
              name="question_<%= question.id %>"
              value="C"
              aria-label="Pregunta <%= index + 1 %> opcion C <%= question.optionC %>"
              <%= oldAnswers[`question_${question.id}`] === "C" ? "checked" : "" %>
            />
            <span class="option-tag" aria-hidden="true">C</span> <%= question.optionC %>
          </label>
        </fieldset>
        <% }) %>

        <button class="btn btn-primary" type="submit" aria-label="Enviar respuestas del examen" data-speak="Enviar respuestas del examen.">
          <span aria-hidden="true">✅</span> Enviar respuestas
        </button>
      </form>
    </main>
    <script src="/js/pageNarration.js"></script>
    <script src="/js/accessibility.js"></script>
  </body>
</html>
