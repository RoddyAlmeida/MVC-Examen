<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="container app-shell" style="text-align: center; padding: 4rem 2rem;">
      <div class="theme-toggle-wrapper">
        <button id="theme-toggle" class="theme-toggle" aria-label="Cambiar modo de color">
          <i class="ti ti-moon" aria-hidden="true"></i>
        </button>
      </div>

      <i class="ti ti-error-404" aria-hidden="true" style="font-size: 5rem; color: var(--text-secondary); margin-bottom: 1rem; display: inline-block;"></i>
      <h1 style="margin-bottom: 0.5rem">404</h1>
      <p class="lead" style="margin-bottom: 2rem;">La página solicitada no existe.</p>
      
      <a class="btn btn-primary" href="/exam/start">
        <i class="ti ti-home" aria-hidden="true"></i> Volver al inicio
      </a>
    </main>
    <script src="/js/themeToggle.js"></script>
  </body>
</html>
