{
  "name": "mvc",
  "version": "1.0.0",
  "description": "Aplicación de exámenes MVC con Electron",
  "author": "El duo dinamita",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node app.js",
    "start": "node app.js",
    "electron": "electron .",
    "seed": "node scripts/seed.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.examen.mvc",
    "productName": "MVC Examen",
    "files": [
      "**/*",
      "!node_modules/electron",
      "!node_modules/electron-builder",
      "!dist"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icons/icon.png"
    },
    "linux": {
      "target": "flatpak",
      "icon": "build/icons/icon.png"
    }
  },
  "dependencies": {
    "@libsql/sqlite3": "0.3.1",
    "dotenv": "17.4.2",
    "ejs": "5.0.2",
    "express": "5.2.1",
    "express-validator": "7.3.2",
    "sequelize": "6.37.8",
    "ee-first": "1.1.1"
  },
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "26.8.1"
  }
}