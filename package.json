{
  "name": "mvc",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node app.js",
    "start": "node app.js",
    "electron": "electron .",
    "seed": "node scripts/seed.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.examen.mvc",
    "productName": "MVC Examen",
    "files": [
      "**/*",
      "!.env",
      "!node_modules/electron",
      "!node_modules/electron-builder"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@libsql/sqlite3": "^0.3.1",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "electron": "^42.0.1"
  },
  "engines": {
    "node": ">=18 <26",
    "npm": ">=9"
  }
}
